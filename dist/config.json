{
	"non_tailwindcss_placement": "front",
	"extensions_regex": {
		"html": {
			"region": "(?<=\\sclass=\\\")((?!\\\").)+(?=\\\")|(?<=\\sclass=')((?!').)+(?=')|(?<=@apply\\s)((?!;).)+(?=;)",
			"class": "[^\\s]+"
		},
		"css": {
			"region": "(?<=@apply\\s)((?!;).)+(?=;)",
			"class": "[^\\s]+"
		},
		"pug": {
			"region": "\\.([a-zA-Z0-9!:_\\-\\.\\[\\]]+)",
			"class": "[^\\.]+",
			"separator": "."
		}
	},
	"order_type": "recess",
	"edit_order": {
		"overwrite": [],
		"amend": [],
		"append": []
	},
	"breakpoint_grouping": "style",
	"variant_ordering": [
		"ltr",
		"rtl",
		"data-*",
		"group-aria-*",
		"peer-aria-*",
		"aria-selected",
		"aria-required",
		"aria-readonly",
		"aria-pressed",
		"aria-hidden",
		"aria-expanded",
		"aria-disabled",
		"aria-checked",
		"aria-*",
		"supports-*",
		"[@supports(*)]",
		"print",
		"contrast-less",
		"contrast-more",
		"motion-reduce",
		"motion-safe",
		"landscape",
		"portrait",
		"dark",
		"@xs",  "@xs/*",
		"@sm",  "@sm/*",  "sm",
		"@md",  "@md/*",  "md",
		"@lg",  "@lg/*",  "lg",
		"@xl",  "@xl/*",  "xl",
		"@2xl", "@2xl/*", "2xl",
		"@3xl", "@3xl/*",
		"@4xl", "@4xl/*",
		"@5xl", "@5xl/*",
		"@6xl", "@6xl/*",
		"@7xl", "@7xl/*",
		"@[*]", "@[*]/*",
		"min-*",
		"max-sm",
		"max-md",
		"max-lg",
		"max-xl",
		"max-2xl",
		"max-*",
		"[@media(*)]",
		"before",
		"after",
		"group-*",
		"peer-*",
		"placeholder",
		"backdrop",
		"file",
		"selection",
