{
	"name": "tailwindcss-class-sorter",
	"description": "tailwindcss Class Sorter",
	"version": "0.1.0",
	"contributors": [
		"Shafiq Tahir <shafiqtahir.khan@gmail.com>"
	],
	"scripts": {
		"generate-css": "NODE_ENV=development node_modules/.bin/tailwindcss -i ./tailwind.css -c ./tailwind.config.js -o ./style.css && node prepare-css.js",
		"generate-order-lists": "node generate-order-list.js"
	},
	"browserslist": [
		"defaults"
	],
	"engines": {
		"node": ">=10.12.0"
	},
	"devDependencies": {
		"@babel/core": "^7.20.12",
		"@babel/eslint-parser": "^7.18.9",
		"@babel/preset-env": "^7.18.10",
		"autoprefixer": "^10.4.8",
		"eslint": "^8.32.0",
		"eslint-config-standard": "^17.0.0",
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-n": "^15.6.1",
		"eslint-plugin-promise": "^6.0.1",
		"eslint-plugin-unicorn": "^45.0.2",
		"postcss": "^8.4.21",
		"stylelint": "^14.16.1",
		"stylelint-config-concentric-order": "^5.1.0",
		"stylelint-config-property-sort-order-smacss": "^9.0.0",
		"stylelint-config-recess-order": "^3.1.0",
		"stylelint-order": "^6.0.1",
		"tailwindcss": "3.2.4"
	},
	"peerDependencies": {
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-n": "^15.6.1",
		"eslint-plugin-promise": "^6.0.1"
	}
}