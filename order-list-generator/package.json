{
	"name": "tailwindcss-class-sorter",
	"description": "tailwindcss Class Sorter",
	"version": "0.1.0",
	"contributors": [
		"Shafiq Tahir <shafiqtahir.khan@gmail.com>"
	],
	"scripts": {
		"generate-css": "NODE_ENV=development node_modules/.bin/tailwindcss -i ./tailwind.css -c ./tailwind.config.js -o ./style.css && node prepare-css.js",
		"generate-order-lists": "node generate-order-list.js"
	},
	"browserslist": [
		"defaults"
	],
	"engines": {
		"node": ">=10.12.0"
	},
	"devDependencies": {
		"@babel/core": "^7.22.9",
		"@babel/eslint-parser": "^7.22.9",
		"@babel/preset-env": "^7.22.9",
		"autoprefixer": "^10.4.14",
		"eslint": "^8.45.0",
		"eslint-config-standard": "^17.1.0",
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-n": "^16.0.1",
		"eslint-plugin-promise": "^6.0.1",
		"eslint-plugin-unicorn": "^48.0.0",
		"postcss": "^8.4.27",
		"stylelint": "^15.10.2",
		"stylelint-config-concentric-order": "^5.1.0",
		"stylelint-config-property-sort-order-smacss": "^9.1.0",
		"stylelint-config-recess-order": "^4.3.0",
		"stylelint-order": "^6.0.3",
		"tailwindcss": "3.3.3"
	}
}