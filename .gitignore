# ------------------------------ #
# -----------General------------ #
# ------------------------------ #

# OS
# Ref: https://github.com/github/gitignore/blob/main/Global/macOS.gitignore
# Ref: https://github.com/github/gitignore/blob/main/Global/Windows.gitignore
# Ref: https://github.com/github/gitignore/blob/main/Global/Linux.gitignore
.DS_Store
Thumbs.db
*.sh
*.bat

# Editors
# Ref: https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
# Ref: https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore
# Ref: https://github.com/github/gitignore/blob/main/Global/SublimeText.gitignore
.history
.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# ------------------------------ #
# ----------JavaScript---------- #
# ------------------------------ #

# Dependencies
node_modules
.pnpm-debug.log

# Compiled
_nodejs_/dist
_nodejs_/style.css
_nodejs_/style-raw.css
_nodejs_/content-prettier.html

# Typescript
_nodejs_/.tsbuildinfo

# ------------------------------ #
# ------------Python------------ #
# ------------------------------ #

# Byte-compiled / optimized / DLL files
_python_/__pycache__/
_python_/*.py[cod]
_python_/*$py.class

# Environments
_python_/.env
_python_/.venv
_python_/env/
_python_/venv/
_python_/ENV/
_python_/env.bak/
_python_/venv.bak/

# Distribution / packaging
_python_/.Python
_python_/build/
_python_/develop-eggs/
_python_/dist/
_python_/downloads/
_python_/eggs/
_python_/.eggs/
_python_/lib/
_python_/lib64/
_python_/parts/
_python_/sdist/
_python_/var/
_python_/wheels/
_python_/pip-wheel-metadata/
_python_/share/python-wheels/
_python_/*.egg-info/
_python_/.installed.cfg
_python_/*.egg
_python_/MANIFEST

# C extensions
_python_/*.so

# Translations
_python_/*.mo
_python_/*.pot

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
_python_/*.manifest
_python_/*.spec

# Installer logs
_python_/pip-log.txt
_python_/pip-delete-this-directory.txt

# pyenv
# _python_/.python-version

# pipenv
# 	According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
# 	However, in case of collaboration, if having platform-specific dependencies or dependencies
# 	having no cross-platform support, pipenv may install dependencies that don't work, or not
# 	install all needed dependencies.
_python_/Pipfile.lock

# PEP 582; used by e.g. github.com/David-OConnor/pyflow
_python_/__pypackages__/

# Unit test / coverage reports
_python_/htmlcov/
_python_/.tox/
_python_/.nox/
_python_/.coverage
_python_/.coverage.*
_python_/.cache
_python_/nosetests.xml
_python_/coverage.xml
_python_/*.cover
_python_/*.py,cover
_python_/.hypothesis/
_python_/.pytest_cache/

# PyBuilder
_python_/target/

# Pyre type checker
_python_/.pyre/

# mypy
_python_/.mypy_cache/
_python_/.dmypy.json
_python_/dmypy.json

# Rope project settings
_python_/.ropeproject

# ------------------------------ #
# ------------Django------------ #
# ------------------------------ #

# Django
_python_/*.log
_python_/local_settings.py
_python_/db.sqlite3
_python_/db.sqlite3-journal

